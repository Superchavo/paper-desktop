#!/bin/bash
# Carpetas seguras en Fedora
DIRS="/usr/share/applications /usr/local/share/applications"
OUTPUT="/tmp/paper-menu.xml"

echo "<JWM>" > $OUTPUT

gen_cat() {
    local label=$1
    local category=$2
    echo "  <Menu label=\" $label\" icon=\"folder\">" >> $OUTPUT
    # Buscamos solo en rutas reales de apps para evitar el Segfault
    for d in $DIRS; do
        if [ -d "$d" ]; then
            grep -l "Categories=.*$category" $d/*.desktop 2>/dev/null | xargs grep -l "NoDisplay=true" -v 2>/dev/null | while read fl; do
                name=$(grep "^Name=" "$fl" | cut -d= -f2 | head -1)
                exec=$(grep "^Exec=" "$fl" | cut -d= -f2 | sed "s/%.//g" | head -1)
                echo "    <Program label=\" $name\">$exec</Program>" >> $OUTPUT
            done
        fi
    done
    echo "  </Menu>" >> $OUTPUT
}

gen_cat "Internet" "Network"
gen_cat "Utilities" "Utility"
gen_cat "System" "System"
gen_cat "Development" "Development"
gen_cat "Games" "Game"

echo "</JWM>" >> $OUTPUT
